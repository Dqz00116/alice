# Copy this file to .env and fill in your Anthropic API key.
# The .env file is ignored by git; keep your real key there.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the Anthropic-compatible API base URL.
# Defaults to https://api.anthropic.com if not set.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: override the Anthropic model ID.
# Defaults to claude-3-5-sonnet-20241022 if not set.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
